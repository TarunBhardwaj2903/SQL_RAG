# =============================================================================
# SQL RAG — .gitignore
# =============================================================================

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# Vite build artifacts
*.timestamp-*.mjs

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Environment variables (NEVER commit these) ────────────────────────────────
# .env.example IS intentionally tracked (it contains placeholder values only)
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
# Explicitly protect the backend env
backend/.env
backend/.env.local
backend/.env.*.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python

# Build artifacts
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.virtualenv/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml
*.cover

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Temporary / Cache ─────────────────────────────────────────────────────────
*.tmp
*.temp
.cache/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Kiro IDE (internal spec/steering files — not for public repos) ────────────
.kiro/

# ── Markdown — ignore internal docs, keep public-facing ones ─────────────────
# Keep: README.md, SECURITY.md, CONTRIBUTING.md (already tracked)
# Ignore all other .md files (dev notes, kiro specs, temp docs)
docs/
*_TEMP.md
*_OLD.md
