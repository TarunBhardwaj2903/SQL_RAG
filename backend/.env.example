# ============================================
# SQL RAG Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# ============================================
# Database Connection
# ============================================
# Supabase PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://username:password@your-project.supabase.co:5432/postgres

# ============================================
# NVIDIA NIM API Configuration
# ============================================
# Get your API key from: https://build.nvidia.com
# Free tier: 1000 credits/month, 40 requests/minute

# API Key (same for both LLM and embeddings)
OPENAI_API_KEY=nvapi-YOUR-NVIDIA-API-KEY-HERE
NVIDIA_API_KEY=nvapi-YOUR-NVIDIA-API-KEY-HERE

# API Base URL (do not change unless using different endpoint)
OPENAI_API_BASE=https://integrate.api.nvidia.com/v1

# LLM Model for SQL generation
# Options: meta/llama-3.3-70b-instruct, meta/llama-3.1-70b-instruct, meta/llama-3.1-8b-instruct
OPENAI_MODEL=meta/llama-3.3-70b-instruct

# ============================================
# RAG (Retrieval-Augmented Generation) Settings
# ============================================
# Embedding model for vector search
NVIDIA_EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2

# Reranking model (currently disabled due to API availability)
NVIDIA_RERANK_MODEL=nvidia/nv-rerankqa-mistral-4b-v3

# Number of candidate tables to retrieve from vector search
RAG_CANDIDATE_COUNT=10

# Number of top tables to send to LLM after reranking
RAG_TOP_K=5

# Enable/disable RAG pipeline (true/false)
RAG_ENABLED=true

# ============================================
# Agent Configuration
# ============================================
# Maximum number of SQL correction retries
MAX_RETRIES=3

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# Optional: OpenAI Configuration (Alternative to NVIDIA)
# ============================================
# If you prefer to use OpenAI instead of NVIDIA for LLM:
# 1. Get API key from: https://platform.openai.com/api-keys
# 2. Uncomment and set these variables:
# 3. Leave OPENAI_API_BASE empty (or remove it)
# 4. Set OPENAI_MODEL to: gpt-4o-mini or gpt-4o

# OPENAI_API_KEY=sk-proj-YOUR-OPENAI-API-KEY-HERE
# OPENAI_API_BASE=
# OPENAI_MODEL=gpt-4o-mini

# ============================================
# Security Notes
# ============================================
# 1. Never commit .env file to git
# 2. Use strong, unique passwords
# 3. Rotate API keys regularly
# 4. Use read-only database user in production
# 5. Enable 2FA on all accounts
# 6. Monitor API usage for anomalies

# ============================================
# Deployment — CORS
# ============================================
# Set this to your Vercel frontend URL after deployment
# e.g. https://sql-rag.vercel.app
FRONTEND_URL=https://your-app.vercel.app
